# BSC-1000 Controller Configuration
# Copy this file to .env and adjust as needed.

# BACnet device instance number (unique per site)
DEVICE_INSTANCE=999001

# BACnet device name
DEVICE_NAME=BACsync Controller

# BACnet/IP UDP port (default: 47808 / 0xBAC0)
BACNET_PORT=47808

# Network interface (uncomment if multiple NICs)
#ETH_INTERFACE=eth0

# Log level (DEBUG, INFO, WARNING, ERROR)
#LOG_LEVEL=INFO

# SSH management console port
#SSH_PORT=2222
